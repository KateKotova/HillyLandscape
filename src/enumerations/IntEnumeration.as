/**
 * Пакет перечислимых типов.
 */
package enumerations
{
	/**
	 * Класс перечисления, значениями элементов которого - целые числа.
	 */
	public class IntEnumeration extends Enumeration
	{
		/**
		 * Значение такущего элемента - значение для данного экземпляра класса.
		 */
		public var Value: int;
	} // IntEnumeration
} // enumerations


