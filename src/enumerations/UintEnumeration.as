/**
 * Пакет перечислимых типов.
 */
package enumerations
{
	/**
	 * Класс перечисления, значениями элементов которого
	 * являются целые неотрицательные числа.
	 */
	public class UintEnumeration extends Enumeration
	{
		/**
		 * Значение текущего элемента - значение для данного экземпляра класса.
		 */
		public var Value: uint;
	} // Enumeration
} // enumerations

